{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [                    // Include all TypeScript files and declaration files
    "next-env.d.ts",              // file khai báo kiểu do Next.js tạo ra, rất quan trọng để Next hiểu đúng môi trường của dự án
    "**/*.d.ts",                  // tất cả các file có phần mở rộng .d.ts trong dự án.
    "**/*.ts",                    // tất cả các file có phần mở rộng .ts trong dự án.
    "**/*.tsx",                   // tất cả các file có phần mở rộng .tsx trong dự án.
    ".next/types/**/*.ts",        // kiểu được Next sinh ra khi build, nằm trong thư mục .next/types.
    ".next/dev/types/**/*.ts",    // kiểu sinh ra trong chế độ dev, nằm trong thư mục .next/dev/types.
    "**/*.mts"                    // file TypeScript theo kiểu ES Module, thường được sử dụng cho các module ES6.
  ],
  "exclude": ["node_modules"]
}
